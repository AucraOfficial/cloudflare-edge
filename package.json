{
  "name": "@aucra/cloudflare-edge",
  "version": "0.1.0",
  "description": "Aucra edge ad injection for Cloudflare Workers",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && npm run bundle",
    "bundle": "esbuild src/worker.ts --bundle --format=iife --global-name=K --outfile=dist/bundle.js --minify",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": ">=4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT"
}
